# ----------------------------------------------------------------------------
# LTL TV — example environment
# Copy this file to `.env` at the repo root and adjust for each environment.
# ----------------------------------------------------------------------------

# Django
SECRET_KEY=change-me-please
DEBUG=False
ALLOWED_HOSTS=ltltv.com,www.ltltv.com,localhost,127.0.0.1

# Database (used by docker-compose + Django)
POSTGRES_DB=ltltv
POSTGRES_USER=ltltv
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://ltltv:change-me@db:5432/ltltv

# Cache / Celery
REDIS_URL=redis://redis:6379/0

# Cloudinary (media storage) — leave empty in local dev to use local filesystem
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://ltltv.com,https://www.ltltv.com,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://ltltv.com,https://www.ltltv.com,http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=https://ltltv.com
NEXT_PUBLIC_SITE_URL=https://ltltv.com
